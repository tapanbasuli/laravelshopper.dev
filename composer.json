{
  "name": "shopper/framework",
  "description": "An e-commerce administration built with Laravel for create and manage online shop.",
  "license": "MIT",
  "keywords": [
    "e-commerce",
    "TALLStack",
    "Laravel",
    "store"
  ],
  "authors": [
    {
      "name": "Arthur Monney",
      "email": "monneylobe@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "composer-runtime-api": "^2.1",
    "ext-intl": "*"
  },
  "require-dev": {
    "bacon/bacon-qr-code": "^2.0",
    "blade-ui-kit/blade-heroicons": "^2.5",
    "codeat3/blade-phosphor-icons": "^2.3",
    "codewithdennis/filament-select-tree": "^4.0",
    "danharrin/livewire-rate-limiting": "^1.0|^2.0",
    "filament/filament": "^4.5",
    "filament/spatie-laravel-media-library-plugin": "^4.5",
    "gehrisandro/tailwind-merge-laravel": "^1.3",
    "ivanmitrikeski/laravel-shipping": "^1.0",
    "jaocero/radio-deck": "^2.0",
    "jenssegers/agent": "^2.6",
    "larastan/larastan": "^3.8",
    "laravel/framework": "^11.0|^12.0",
    "laravel/pint": "^1.16",
    "mckenziearts/filament-untitledui-icons": "^1.0",
    "milon/barcode": "^11.0|^12.0",
    "mockery/mockery": "^1.4",
    "nunomaduro/collision": "^7.10.0|^8.1.1",
    "orchestra/testbench": "^8.20|^9.0|^10.0",
    "pestphp/pest": "^3.8|^4.0",
    "pestphp/pest-plugin-laravel": "^3.0|^4.0",
    "pestphp/pest-plugin-livewire": "^3.0|^4.0",
    "pestphp/pest-plugin-type-coverage": "^3.6|^4.0",
    "pragmarx/google2fa": "^8.0|^9.0",
    "rector/rector": "^2.3",
    "shopper/core": "*",
    "spatie/laravel-livewire-wizard": "^2.4",
    "spatie/laravel-package-tools": "^1.15",
    "stevebauman/location": "^7.2",
    "symplify/monorepo-builder": "^11.0"
  },
  "autoload": {
    "files": [
      "packages/admin/src/helpers.php",
      "packages/core/src/helpers.php",
      "packages/sidebar/src/helpers.php"
    ],
    "psr-4": {
      "Shopper\\": [
        "packages/admin/src",
        "packages/core/src",
        "packages/sidebar/src",
        "packages/shipping/src"
      ],
      "Shopper\\Core\\": "packages/core/src",
      "Shopper\\Shipping\\": "packages/shipping/src",
      "Shopper\\Sidebar\\": "packages/sidebar/src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Shopper\\ShopperServiceProvider",
        "Shopper\\Core\\CoreServiceProvider",
        "Shopper\\Shipping\\ShippingServiceProvider",
        "Shopper\\Sidebar\\SidebarServiceProvider"
      ]
    }
  },
  "scripts": {
    "cs": [
      "refactor",
      "lint",
      "npx run prettier"
    ],
    "lint": "pint",
    "refactor": "rector",
    "test:lint": "pint --test",
    "test:refactor": "./vendor/bin/rector --dry-run",
    "test:unit": "pest --colors=always --coverage --parallel --min=80",
    "test:sqlite": "pest --configuration=phpunit.sqlite.xml --colors=always --parallel",
    "test:mysql": "pest --configuration=phpunit.mysql.xml --colors=always --parallel",
    "test:pgsql": "pest --configuration=phpunit.pgsql.xml --colors=always --parallel",
    "test:types": "phpstan analyse --ansi --memory-limit=-1",
    "test:type-coverage": "pest --type-coverage --min=90 --memory-limit=-1",
    "test:all-databases": [
      "@test:sqlite",
      "@test:mysql",
      "@test:pgsql"
    ],
    "test": [
      "@test:type-coverage",
      "@test:types",
      "@test:sqlite"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "packages/core"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
