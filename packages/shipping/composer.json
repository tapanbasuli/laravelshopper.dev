{
  "name": "shopper/shipping",
  "description": "Laravel Shopper shipping providers integration",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "shopper/core": "*",
    "ivanmitrikeski/laravel-shipping": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Shopper\\Shipping\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Shopper\\Shipping\\ShippingServiceProvider"
      ],
      "dont-discover": [
        "ivanmitrikeski/laravel-shipping"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
