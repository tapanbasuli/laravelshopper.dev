{
  "name": "shopper/core",
  "description": "Shopper e-commerce core functionality",
  "license": "MIT",
  "require": {
    "ext-intl": "*",
    "php": "^8.3",
    "laravel/prompts": "^0.3.5",
    "illuminate/console": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0",
    "illuminate/support": "^11.0|^12.0",
    "spatie/laravel-package-tools": "^1.19",
    "staudenmeir/laravel-adjacency-list": "^1.0"
  },
  "autoload": {
    "files": [
      "src/helpers.php"
    ],
    "psr-4": {
      "Shopper\\Core\\": "src/",
      "Shopper\\Core\\Database\\Factories\\": "database/factories",
      "Shopper\\Core\\Database\\Seeders\\": "database/seeders"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Shopper\\Core\\CoreServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
