{
  "compilerOptions": {
    "module": "CommonJS",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "outDir": "dist",
    "declarationDir": "dist",
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strictFunctionTypes": true,
    "strictNullChecks": true,
    "types": [],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
