{
  "name": "laravel-shopper",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./packages/admin/resources/css/shopper.css -o ./packages/admin/dist/shopper.css --watch",
    "dev:js": "node scripts/build.js --dev",
    "dev": "npm-run-all --parallel dev:*",
    "build:css": "npx @tailwindcss/cli -i ./packages/admin/resources/css/shopper.css -o ./packages/admin/dist/shopper.css --minify",
    "build:js": "node scripts/build.js",
    "build": "npm-run-all build:*",
    "prettier": "npx prettier --write ./packages/admin/resources"
  },
  "devDependencies": {
    "@alpinejs/focus": "^3.15.4",
    "@awcodes/alpine-floating-ui": "^3.6.4",
    "@ryangjchandler/alpine-tooltip": "^2.0",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.23",
    "esbuild": "^0.27.2",
    "esbuild-postcss": "^0.0.4",
    "lodash": "^4.17.23",
    "npm-run-all": "^4.1.5",
    "popper.js": "^1.16.1",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.0",
    "prettier-plugin-blade": "^2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "resolve-url-loader": "^5.0.0",
    "shiki": "^3.21.0",
    "sortablejs": "^1.15.6",
    "tailwindcss": "^4.2.1"
  }
}
